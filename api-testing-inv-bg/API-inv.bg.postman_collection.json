  "item": [
    {
      "name": "GET /firm - auth smoke",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// 1. Status code\r",
              "pm.test(\"Status is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// 2. Format — отговорът е JSON\r",
              "pm.test(\"Response is JSON\", function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "// 3. Data — правилната фирма\r",
              "pm.test(\"Firm id is 122616\", function () {\r",
              "    pm.expect(pm.response.json().id).to.eql(122616);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{inv_token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/firm",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "firm"
          ]
        }
