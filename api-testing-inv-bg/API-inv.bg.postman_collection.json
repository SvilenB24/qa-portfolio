    {
      "name": "Get /clients - list (200)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));\r",
              "pm.test(\"Response is JSON\", () => pm.response.to.be.json);\r",
              "pm.test(\"Has pagination + clients array\", () => {\r",
              "    const b = pm.response.json();\r",
              "    pm.expect(b.total).to.be.a('number');\r",
              "    pm.expect(b.clients).to.be.an('array');\r",
              "    pm.expect(b).to.have.property('next_page');\r",
              "    pm.expect(b).to.have.property('prev_page');\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{inv_token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/clients",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "clients"
          ]
        }
      },
      "response": []
    },
    {
      "name": "POST /clients (create) (201)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 201 Created\", () => pm.response.to.have.status(201));\r",
              "pm.test(\"Returns an id\", () => {\r",
              "    const id = pm.response.json().id;\r",
              "    pm.expect(id).to.be.a('number');\r",
              "    pm.collectionVariables.set(\"client_id\", id);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const b = String(Math.floor(100000000 + Math.random() * 900000000));\r",
              "pm.collectionVariables.set(\"bulstat\", b);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{inv_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"Test Client QA\",\r\n  \"bulstat\": \"{{bulstat}}\",\r\n  \"mol\": \"Ivan Ivanov\",\r\n  \"is_reg_vat\": false\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/clients",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "clients"
          ]
        }
      },
      "response": []
    },
    {
      "name": "GET /clients/{{client_id}} (verify created)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", () => pm.response.to.have.status(200));\r",
              "pm.test(\"Client data matches what was created\", () => {\r",
              "    const b = pm.response.json();\r",
              "    pm.expect(b.name).to.eql(\"Test Client QA\");\r",
              "    pm.expect(b.bulstat).to.eql(pm.collectionVariables.get(\"bulstat\"));\r",
              "    pm.expect(b.mol).to.eql(\"Ivan Ivanov\");\r",
              "    pm.expect(b.is_reg_vat).to.eql(false);\r",
              "});"
            ],
